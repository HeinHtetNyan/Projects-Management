# PostgreSQL — same DB as the legacy app, or a separate one
DATABASE_URL=postgresql://postgres:postgres@db:5432/licensedb

# JWT secret — run: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-random-hex-string

# Fernet key — same as legacy ENCRYPTION_KEY (secrets vault uses the same key)
ENCRYPTION_KEY=change-me-run-generate_key.py-to-get-this

# First admin user (auto-created on first run if no admins exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Base URL of THIS backend server (used to build activation links)
BASE_URL=https://activate.sawyuntech.com

# App name shown in responses
APP_NAME=Saw Yun License Server

# Comma-separated allowed origins for CORS (your Vercel frontend URL + localhost for dev)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# PostgreSQL password (for docker-compose db container)
POSTGRES_PASSWORD=change-me-strong-db-password

# JWT token lifetime in hours (default 8)
ACCESS_TOKEN_EXPIRE_HOURS=8
